# ===== Privy (auth + embedded wallets) =====
# Public — exposed to browser
NUXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NUXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id

# Server-only — used by @privy-io/node to verify access tokens
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
NUXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id

# ===== Supabase (database only — auth is Privy) =====
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ===== Solana =====
NUXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta
NUXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Mainnet CAIP-2 chain ID used by Privy for transaction signing
SOLANA_CAIP2=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# ===== App =====
NUXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Jupiter =====
JUPITER_API_KEY=
# Referral account public key — register at referral.jup.ag to collect 0.1% swap fees
JUPITER_REFERRAL_KEY=

# ===== GoldRush (portfolio & wallet risk) =====
GOLDRUSH_API_KEY=

# ===== Privy authorization key (for server-side signing) =====
PRIVY_AUTHORIZATION_KEY_ID=
PRIVY_AUTHORIZATION_PUBLIC_KEY=
PRIVY_AUTHORIZATION_KEY=

# ===== Cron (recurring payments) =====
# Any random secret string — must match what you set in Vercel env vars
CRON_SECRET=your-random-secret-here

# ===== Firebase (push notifications) =====
# Client-side config — from Firebase Console > Project Settings > Your apps
NUXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NUXT_PUBLIC_FIREBASE_APP_ID=your_app_id
# VAPID key from Firebase Console > Cloud Messaging > Web Push certificates
NUXT_PUBLIC_FIREBASE_VAPID_KEY=
# Service account JSON (stringify it): Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT=
